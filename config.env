# ---- Profile A ----
R_VERSION_A=4.4.3
PYTHON_VERSION_A=3.11
JUPYTER_PORT_A=8888
RSTUDIO_PORT_A=8787
VSCODE_PORT_A=8901

# ---- Profile B ----
R_VERSION_B=4.4.3
PYTHON_VERSION_B=3.12
JUPYTER_PORT_B=8902
RSTUDIO_PORT_B=8903
VSCODE_PORT_B=8904

# ---- Shared config ----
WORK_DIR=~/workdir
WORK_MOUNT=/home/workdir

# ---- Packages ----
PACKAGES_DIR=~/packages

# ---- GCP (optional) ----
GCP_SERVICE_ACCOUNT_KEY=./claude-default-sa-key.json

# Bucket folder access — space-separated "gs://bucket/prefix:ro|rw" entries.
# Paths not listed here are not exposed to containers (no access).
GCP_BUCKET_ACCESS="gs://mlab-ai-readable/mraj:ro gs://mlab-ai-writable/mraj:rw"

# Auto-derived from GCP_SERVICE_ACCOUNT_KEY by run.sh. Override here only if needed:
# GCP_VOLUMES="-v /custom/path/key.json:/run/secrets/gcp-key.json:ro,Z"
# GCP_ENV="-e GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json"
