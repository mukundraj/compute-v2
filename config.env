# ---- Profile A ----
R_VERSION_A=4.3.2
PYTHON_VERSION_A=3.11

# ---- Profile B ----
R_VERSION_B=4.4.0
PYTHON_VERSION_B=3.12

# ---- Ports ----
JUPYTER_PORT_A=8888
RSTUDIO_PORT_A=8787
JUPYTER_PORT_B=8889
RSTUDIO_PORT_B=8788

# ---- Shared config ----
WORK_DIR=~/work
PNPM_HOME=$(pnpm bin -g 2>/dev/null || echo "$HOME/.local/share/pnpm")
RSTUDIO_PASSWORD=yourpassword

# ---- GCP (optional) ----
# GCP_SERVICE_ACCOUNT_KEY=~/path/to/key.json

# Auto-derived from GCP_SERVICE_ACCOUNT_KEY by run.sh. Override here only if needed:
# GCP_VOLUMES="-v /custom/path/key.json:/run/secrets/gcp-key.json:ro,Z"
# GCP_ENV="-e GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json"
